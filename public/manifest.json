{
  "manifest_version": 3,
  "name": "Site Limiter",
  "version": "1.0",
  "description": "命を削ってコードを書くための、任意のWebサイト封印ツール",
  "permissions": ["storage", "nativeMessaging"],
  "background": {
    "service_worker": "background.js"
  },
  "options_page": "index.html",
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "action": {
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    },
    "default_title": "Site Limiter"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}